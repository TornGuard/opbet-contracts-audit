{
  "name": "opbet-contracts",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build:token": "asc src/token/index.ts --config asconfig.token.json --target debug",
    "build:market": "asc src/market/index.ts --config asconfig.market.json --target debug",
    "build:raise": "asc src/raise/index.ts --config asconfig.raise.json --target debug",
    "build:oracle": "asc src/oracle/index.ts --config asconfig.oracle.json --target debug",
    "build": "npm run build:token && npm run build:market && npm run build:raise && npm run build:oracle",
    "test:oracle": "TSX_TSCONFIG_PATH=tsconfig.test.json node --import ./node_modules/tsx/dist/esm/index.mjs test/price-oracle.test.mts",
    "test:raise": "node --import ./node_modules/tsx/dist/esm/index.mjs test/opbet-raise.test.mts",
    "test:raise:ts": "node --import ./node_modules/tsx/dist/esm/index.mjs test/opbet-raise.test.ts",
    "test:token": "node --import ./node_modules/tsx/dist/esm/index.mjs test/opbet-token.test.mts",
    "clean": "rm -rf build/*",
    "postinstall": "node scripts/patch-noble-hashes.js"
  },
  "dependencies": {
    "@btc-vision/as-bignum": "0.1.2",
    "@btc-vision/btc-runtime": "rc"
  },
  "devDependencies": {
    "@btc-vision/assemblyscript": "^0.29.2",
    "@btc-vision/op-vm": "^1.0.0-rc.2",
    "@btc-vision/opnet-transform": "1.1.0",
    "@btc-vision/unit-test-framework": "^1.0.0-beta.0",
    "dotenv": "^17.3.1",
    "tsx": "^4.21.0"
  },
  "overrides": {
    "@noble/hashes": "2.0.1"
  }
}
